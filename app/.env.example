# =============================================================================
# LiveNotebookLM Environment Configuration
# Copy to .env and fill in your values. Do not commit .env to version control.
# =============================================================================
# --- Vertex AI Live API ---
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=your_gcp_project_id
GOOGLE_CLOUD_LOCATION=us-central1

# --- Model ---
# Must support Live API
#   Gemini: gemini-2.5-flash-native-audio-preview-12-2025
#   Vertex: gemini-live-2.5-flash-native-audio
LIVE_NOTEBOOK_AGENT_MODEL=YOUR_VERTEX_LIVE_MODEL

# --- Cloud Storage (for document/source storage, NotebookLM-style) ---
# GCS_BUCKET_NAME=your-bucket-name

# --- Server ---
PORT=8080
HOST=0.0.0.0
