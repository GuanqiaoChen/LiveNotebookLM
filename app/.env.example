# =============================================================================
# LiveNotebookLM Environment Configuration
# Copy to .env and fill in your values. Do not commit .env to version control.
# =============================================================================

# --- Platform Selection ---
# Set to TRUE for Vertex AI Live API (recommended for production on GCP)
# Set to FALSE for Gemini Live API (Google AI Studio)
GOOGLE_GENAI_USE_VERTEXAI=false

# --- Gemini Live API (when GOOGLE_GENAI_USE_VERTEXAI=false) ---
# Get key from https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_api_key_here

# --- Vertex AI Live API (when GOOGLE_GENAI_USE_VERTEXAI=true) ---
# GOOGLE_CLOUD_PROJECT=your_gcp_project_id
# GOOGLE_CLOUD_LOCATION=us-central1

# --- Model ---
# Must support Live API. Examples:
#   Gemini: gemini-2.5-flash-native-audio-preview-12-2025
#   Vertex: gemini-live-2.5-flash-native-audio
LIVE_NOTEBOOK_AGENT_MODEL=gemini-2.5-flash-native-audio-preview-12-2025

# --- Cloud Storage (for document/source storage, NotebookLM-style) ---
# GCS_BUCKET_NAME=your-bucket-name

# --- Server ---
PORT=8080
HOST=0.0.0.0
